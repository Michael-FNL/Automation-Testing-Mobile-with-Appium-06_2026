<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
        <!--
            This file plugs into your existing pom.xml surefire config:

                <suiteXmlFile>src/test/resources/${suite}.xml</suiteXmlFile>

            Save this as: src/test/resources/cucumber.xml
            Then run:     mvn clean test -Dsuite=cucumber
        -->
<suite name="Smoke Suite" verbose="1">
<test name="Cucumber Test">
    <classes>
        <class name="com.mobile.testing.runners.CucumberTestRunner"/>
    </classes>
</test>
</suite>